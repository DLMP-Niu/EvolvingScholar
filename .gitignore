# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Environment / secrets
.env
.claude/settings.local.json

# Local-only agent memory (dev-facing; keep out of history if you prefer)
# CLAUDE.local.md   # uncomment to keep dev notes untracked

# Reference PDFs (download separately; not committed)
docs/references/*.pdf

# Data — keep bulk cohort files out of git (synthetic, but regenerable from the generator).
# Ignore everything under data/ except its README and the keep-file.
data/*
!data/README.md
!data/.gitkeep

# Per-scholar run outputs — keep readable results + provenance (report, review, feedback,
# meta, questions, config); ignore only the bulky raw capture layers.
scholars/*/runs/*/transcript.jsonl
scholars/*/runs/*/messages.jsonl
scholars/*/runs/*/thinking.jsonl
scholars/*/runs/*/actions.jsonl

# OS / WSL
.DS_Store
*:Zone.Identifier

# git bundles (transfer artifacts from cloud plan hand-offs)
*.bundle
