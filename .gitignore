# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Environment / secrets
.env
.claude/settings.local.json

# Local-only agent memory (dev-facing; keep out of history if you prefer)
# CLAUDE.local.md   # uncomment to keep dev notes untracked

# Reference PDFs (download separately; not committed)
docs/references/*.pdf

# Data — keep bulk cohort files out of git (synthetic, but regenerable from the generator).
# Ignore everything under data/ except its README and the keep-file.
data/*
!data/README.md
!data/.gitkeep
experiments/runs/**/*.log

# OS / WSL
.DS_Store
*:Zone.Identifier
